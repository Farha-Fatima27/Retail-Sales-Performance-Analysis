      <column caption='Age Group' datatype='string' name='[Calculation_0656707813883904]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [Age] &lt;= 24 then &apos;18-24&apos;&#13;&#10;ELSEIF [Age] &gt;= 25 and [Age] &lt;=35 then &apos;25-35&apos;&#13;&#10;ELSEIF [Age] &gt;=36 and [Age] &lt;= 50 then &apos;36-50&apos;&#13;&#10;ELSE &apos;51+&apos; END' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_0656707817422849]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF {FIXED [Customer_ID] : COUNTD([Transaction_ID])} =1 then &apos;One-Time&apos;&#13;&#10;ELSE &apos;Repeat&apos;&#13;&#10;END' />
      </column>
      <column caption='Average Order Value' datatype='real' default-format='c&quot;₹ &quot;#,##0;&quot;₹ &quot;-#,##0' name='[Calculation_0656707825516546]' role='measure' type='quantitative'>
